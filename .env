# ==============================================================================
# MediAI - Enterprise Healthcare Platform Environment Variables Configuration
# ==============================================================================

# Application Context
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 1. Primary Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mediai?schema=public"

# 2. Cache & Session Storage (Redis)
REDIS_URL="redis://localhost:6379"

# 3. NextAuth Authentication Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="7f3c4dbde0ef14dbf77c8e9b6a12f91a50c822ffb7617c0c1b48b99148d42d38" # Mock generated secret

# OAuth Credentials (Google)
GOOGLE_CLIENT_ID="mock-google-client-id"
GOOGLE_CLIENT_SECRET="mock-google-client-secret"

# 4. AI Diagnosis Layer (OpenAI)
OPENAI_API_KEY="sk-proj-mockopenapikeyformediaiprojectfoundation"

# 5. Blockchain Node Layer (Hyperledger Fabric Abstraction Layer)
BLOCKCHAIN_NODE_URL="http://localhost:8080/api/v1"
BLOCKCHAIN_CHANNEL="mediai-channel"
BLOCKCHAIN_CHAINCODE="emr-ledger"
BLOCKCHAIN_USER_MSP="Org1MSP"
BLOCKCHAIN_USER_CERT_PEM="-----BEGIN CERTIFICATE-----\nMII...\n-----END CERTIFICATE-----"
BLOCKCHAIN_USER_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----"
