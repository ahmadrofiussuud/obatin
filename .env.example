# ==============================================================================
# MediAI - Enterprise Healthcare Platform Environment Variables Configuration
# ==============================================================================

# Application Context
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 1. Primary Database Connection (PostgreSQL)
# Prisma supports PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mediai?schema=public"

# 2. Cache & Session Storage (Redis)
REDIS_URL="redis://:password@localhost:6379/0"

# 3. NextAuth Authentication Configuration
# Run `openssl rand -base64 32` or generate a random key to set as NEXTAUTH_SECRET
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-nextauth-key-change-this-in-production"

# OAuth Credentials (Google)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# 4. AI Diagnosis Layer (OpenAI)
OPENAI_API_KEY="sk-proj-placeholderopenapikeyformediaiprojectfoundation"

# 5. Blockchain Node Layer (Hyperledger Fabric Abstraction Layer)
# Used to authenticate API calls to the Hyperledger chaincode REST gateway (or mock server)
BLOCKCHAIN_NODE_URL="http://localhost:8080/api/v1"
BLOCKCHAIN_CHANNEL="mediai-channel"
BLOCKCHAIN_CHAINCODE="emr-ledger"
BLOCKCHAIN_USER_MSP="Org1MSP"
BLOCKCHAIN_USER_CERT_PEM="-----BEGIN CERTIFICATE-----\nMII...\n-----END CERTIFICATE-----"
BLOCKCHAIN_USER_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----"
